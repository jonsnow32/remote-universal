# Supabase (Cloud SDK + Backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Expo / EAS
EXPO_TOKEN=your-expo-token

# Samsung SmartThings
SAMSUNG_SMARTTHINGS_API_KEY=your-smartthings-api-key

# LG ThinQ
LG_THINQ_ACCESS_TOKEN=your-thinq-access-token

# Daikin Cloud (Onecta)
DAIKIN_CLOUD_ACCESS_TOKEN=your-daikin-access-token

# MQTT Broker (OTA & device sync)
MQTT_BROKER_URL=mqtt://your-broker:1883
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password
