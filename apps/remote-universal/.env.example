# Backend API URL
# - iOS Simulator / Android Emulator: http://localhost:3000 (default, no change needed)
# - Real iOS/Android device: use your Mac's LAN IP address
#   Find it: System Settings > Network > Wi-Fi > Details
#   Example:
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:3000

# Supabase (device catalog – public read-only)
EXPO_PUBLIC_SUPABASE_URL=https://glodilldtusvursprqia.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-publishable-key>
