<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Config for LAN device control (TV remotes, ACs, etc.)

  Release builds on Android 9+ block cleartext HTTP by default. This app
  communicates with local network devices (Samsung/LG/Android TVs, Daikin ACs)
  that use plain HTTP for discovery (SSDP device descriptions) and control APIs.
  Cleartext must be permitted globally since Android NSC cannot express IP ranges.

  HTTPS to the internet is not affected — trust anchors remain system-only.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
