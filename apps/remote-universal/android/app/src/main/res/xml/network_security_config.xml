<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for LAN devices (Samsung TV port 8001, etc.) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- Trust system CAs -->
            <certificates src="system" />
            <!-- Trust user-added CAs (for Samsung TV self-signed certs on port 8002) -->
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
