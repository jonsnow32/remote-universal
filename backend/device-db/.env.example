# Supabase — fill in from your Supabase project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase direct DB connection — for running SQL migrations
# Found in: Supabase Dashboard → Settings → Database → Connection string (URI)
# SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# GitHub PAT — raises GitHub API rate limit from 60 → 5000 req/hr (optional)
# GITHUB_TOKEN=ghp_xxx

# Crawl cache directory — raw downloads are stored here (default: /tmp/crawl)
# CRAWL_CACHE_DIR=/tmp/crawl

# Snapshot output directory (default: /tmp/snapshots)
# SNAPSHOT_DIR=/tmp/snapshots

# Set to "1" for verbose logging
# VERBOSE=1
