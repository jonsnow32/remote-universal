    "export-sqlite:schema": "ts-node src/export-sqlite.ts --schema"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "dotenv": "^17.3.1",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "better-sqlite3": "^12.8.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
