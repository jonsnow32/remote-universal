{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-native",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@remote/core": ["packages/core/src/index.ts"],
      "@remote/ui-kit": ["packages/ui-kit/src/index.ts"],
      "@remote/device-sdk": ["packages/device-sdk/src/index.ts"],
      "@remote/native-modules": ["packages/native-modules/src/index.ts"],
      "@remote/cloud-sdk": ["packages/cloud-sdk/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".expo"]
}
